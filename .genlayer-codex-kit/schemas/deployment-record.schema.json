{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Deployment Record",
  "type": "object",
  "required": [
    "network",
    "contract_address",
    "source_hash",
    "dependency_versions",
    "evidence"
  ],
  "properties": {
    "network": {
      "type": "string"
    },
    "contract_address": {
      "type": "string"
    },
    "transaction_hash": {
      "type": "string"
    },
    "source_hash": {
      "type": "string"
    },
    "dependency_versions": {
      "type": "object"
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "evidence.schema.json"
      }
    }
  },
  "additionalProperties": false
}