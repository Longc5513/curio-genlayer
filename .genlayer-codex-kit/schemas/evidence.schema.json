{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Evidence",
  "type": "object",
  "required": [
    "classification",
    "source_type",
    "location",
    "summary",
    "confidence"
  ],
  "properties": {
    "classification": {
      "enum": [
        "OBSERVED",
        "INFERRED",
        "MISSING",
        "MANUAL_REVIEW_REQUIRED"
      ]
    },
    "source_type": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "confidence": {
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "hash": {
      "type": "string"
    },
    "collected_at": {
      "type": "string"
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}