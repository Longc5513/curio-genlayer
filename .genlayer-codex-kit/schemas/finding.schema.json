{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Finding",
  "type": "object",
  "required": [
    "rule_id",
    "severity",
    "classification",
    "title",
    "explanation",
    "evidence",
    "confidence",
    "remediation",
    "manual_review_required"
  ],
  "properties": {
    "rule_id": {
      "type": "string",
      "pattern": "^GL-"
    },
    "severity": {
      "enum": [
        "blocker",
        "high",
        "medium",
        "low",
        "info"
      ]
    },
    "classification": {
      "enum": [
        "OBSERVED",
        "INFERRED",
        "MISSING",
        "MANUAL_REVIEW_REQUIRED"
      ]
    },
    "title": {
      "type": "string"
    },
    "explanation": {
      "type": "string"
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "evidence.schema.json"
      }
    },
    "confidence": {
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "remediation": {
      "type": "string"
    },
    "manual_review_required": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}