{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Review Report",
  "type": "object",
  "required": [
    "rubric_version",
    "gate_decision",
    "gate_reasons",
    "findings",
    "scores",
    "overall_opinion",
    "missing_information",
    "manual_checks_required"
  ],
  "properties": {
    "rubric_version": {
      "type": "string"
    },
    "gate_decision": {
      "enum": [
        "REJECT",
        "REQUEST_MORE_INFO",
        "ACCEPT_FOR_SCORING"
      ]
    },
    "gate_reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "finding.schema.json"
      }
    },
    "scores": {
      "type": "object",
      "required": [
        "genlayer_fit",
        "contract_quality",
        "engineering",
        "frontend_ux"
      ],
      "properties": {
        "genlayer_fit": {
          "type": "object",
          "required": [
            "score",
            "evidence",
            "note"
          ],
          "properties": {
            "score": {
              "type": "integer",
              "minimum": 0,
              "maximum": 5
            },
            "evidence": {
              "type": "array",
              "items": {
                "$ref": "evidence.schema.json"
              }
            },
            "note": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "contract_quality": {
          "type": "object",
          "required": [
            "score",
            "evidence",
            "note"
          ],
          "properties": {
            "score": {
              "type": "integer",
              "minimum": 0,
              "maximum": 5
            },
            "evidence": {
              "type": "array",
              "items": {
                "$ref": "evidence.schema.json"
              }
            },
            "note": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "engineering": {
          "type": "object",
          "required": [
            "score",
            "evidence",
            "note"
          ],
          "properties": {
            "score": {
              "type": "integer",
              "minimum": 0,
              "maximum": 5
            },
            "evidence": {
              "type": "array",
              "items": {
                "$ref": "evidence.schema.json"
              }
            },
            "note": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "frontend_ux": {
          "type": "object",
          "required": [
            "score",
            "evidence",
            "note"
          ],
          "properties": {
            "score": {
              "type": "integer",
              "minimum": 0,
              "maximum": 5
            },
            "evidence": {
              "type": "array",
              "items": {
                "$ref": "evidence.schema.json"
              }
            },
            "note": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "overall_opinion": {
      "type": "string"
    },
    "missing_information": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "manual_checks_required": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "source_verification": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": false
}