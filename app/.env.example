# Deployed CurioLearningBounties Intelligent Contract address.
# Leave blank to render an honest "integration unavailable" state.
VITE_GENLAYER_CONTRACT_ADDRESS=

# localnet | studionet | testnetAsimov | testnetBradbury
VITE_GENLAYER_NETWORK=testnetBradbury

# Verified explorer base used for outbound transaction links.
VITE_GENLAYER_EXPLORER_URL=

# Usually "/" locally. GitHub Pages sets /REPOSITORY_NAME/ automatically.
VITE_BASE_PATH=/
